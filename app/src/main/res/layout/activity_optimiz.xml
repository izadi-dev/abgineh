<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:orientation="vertical"
android:layout_marginTop="30dp"
android:background="@color/colorBackground"
    >

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#367A38"
        android:elevation="1dp"
        android:textAlignment="center"
        app:titleTextColor="@color/colorText">


    <TextView
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="18sp"
        android:layout_marginLeft="25dp"
        android:layout_gravity="end"
        android:textColor="@color/colorBackground"
        />
    </androidx.appcompat.widget.Toolbar>
    <com.example.abgineh.SheetView

        android:background="@drawable/border_style"
        android:id="@+id/sheetView"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="80dp"
        tools:ignore="MissingConstraints" />


<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:layout_marginTop="5dp"
    android:orientation="horizontal">
    <Button
        android:id="@+id/btnPrev"
        android:textColor="@color/colorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="قبلی"
        android:textSize="20sp"
        android:background="@drawable/btn_style"
        android:layout_marginStart="0dp"
        tools:ignore="ButtonStyle,HardcodedText" />


    <TextView
        android:id="@+id/pageNum"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="0dp"
        android:gravity="center"
        android:hint="شماره صفحه"
        android:textColor="@color/colorText"
        android:textColorHint="@color/colorText"
        tools:ignore="HardcodedText,RtlHardcoded" />

    <Button
        android:id="@+id/btnNext"
        android:textColor="@color/colorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="بعدی"
        android:textSize="20sp"
        android:background="@drawable/btn_style"
        android:layout_marginStart="00dp"
        tools:ignore="ButtonStyle,HardcodedText" />
</LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnPdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="1dp"
            android:background="@drawable/btn_style1"
            android:text="خروجی PDF"
            android:textColor="@color/colorText"
            android:textSize="20dp" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btninvoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="1dp"
            android:background="@drawable/btn_style"
            android:text="فاکتور"
            android:textColor="@color/colorText"
            android:textSize="20dp" />
    </LinearLayout>


</LinearLayout>