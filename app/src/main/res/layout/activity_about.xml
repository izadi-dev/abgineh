<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="20dp">
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@color/colorBackground"
        >
        <ImageView

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@mipmap/ic_launcher"
            />
        <TextView
            android:layout_marginTop="10dp"
            android:id="@+id/txtabout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textSize="20sp"
            android:textColor="@color/colorPrimary"
            android:text="آبگینه یک برنامه برش شیشه و محاسبات شیشه است که با حدف ساده سازی فرایند کاری و افزایش دقت در اندازه گیری طراحی شده است.
            در این برنامه تلاش شده ابزار ها وآموش های کاربردی در اختیار کاربران قرار گیرد تا در محاسبات و اطلاعات مورد نیاز خود سریع و آسان تر انجام دهند.
             از اینکه آبگینه را انتخاب کرده اید سپاسگذاریم"
            />
    </LinearLayout>

</LinearLayout>